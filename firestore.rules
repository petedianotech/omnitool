rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (optional)
    //   - role: string (enum: 'user', 'admin')
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "petedianotech@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return (!('email' in data) || data.email is string) &&
             (!('role' in data) || data.role in ['user', 'admin']);
    }

    function hasOnlyAllowedFields(data, allowedFields) {
      return data.keys().hasOnly(allowedFields);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && 
                       isOwner(userId) && 
                       isValidUser(request.resource.data) && 
                       hasOnlyAllowedFields(request.resource.data, ['email', 'role']) &&
                       (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && 
                       isOwner(userId) && 
                       isValidUser(request.resource.data) && 
                       hasOnlyAllowedFields(request.resource.data, ['email', 'role']) &&
                       (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
