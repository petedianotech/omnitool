{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"]
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "User"
      },
      "description": "User profiles"
    }
  }
}
